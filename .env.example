# --- Database ---
DATABASE_URL=postgres://postgres:postgres@localhost:5433/cardmkt

# --- Stellar network (testnet) ---
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# --- Deployed marketplace contract (filled in after `pnpm contract:deploy`) ---
CONTRACT_ID=

# --- Test payment asset (filled in after `pnpm stellar:setup`) ---
USDC_ASSET_CODE=USDC
USDC_ISSUER=

# --- Platform accounts (filled in after `pnpm stellar:setup`) ---
# Issuer of card assets + the platform fee collector
PLATFORM_ISSUER=
PLATFORM_ISSUER_SECRET=

# --- Web (Next.js, public) ---
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_EXPLORER_URL=https://stellar.expert/explorer/testnet
