# --- Database ---
DATABASE_URL=postgres://postgres:postgres@localhost:5433/cardmkt

# --- Stellar network (testnet) ---
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# --- Deployed marketplace contract (filled in after `pnpm contract:deploy`) ---
CONTRACT_ID=

# --- Test payment asset (filled in after `pnpm stellar:setup`) ---
USDC_ASSET_CODE=USDC
USDC_ISSUER=

# --- Platform accounts (filled in after `pnpm stellar:setup`) ---
# Issuer of card assets + the platform fee collector
PLATFORM_ISSUER=
PLATFORM_ISSUER_SECRET=

# Dispute arbiter secret for physical-escrow orders (separate from the admin).
# The API signs `resolve` with this key; leave empty to disable arbitration
# (the /api/tx/resolve route then returns 501).
ARBITER_SECRET=

# --- IPFS card art (optional) ---
# Uploaded card images are pinned to IPFS and stored as ipfs://<CID> when a
# provider is configured; with neither set, images are stored inline (data URL).
# Local dev: the docker-compose Kubo node. Production: leave IPFS_API_URL empty
# and set PINATA_JWT + your dedicated gateway.
IPFS_API_URL=http://localhost:5001
IPFS_GATEWAY_URL=http://localhost:8080
PINATA_JWT=

# --- Web (Next.js, public) ---
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_EXPLORER_URL=https://stellar.expert/explorer/testnet

# Toggle to turn on/off the maintenance page (true | false)
NEXT_PUBLIC_MAINTENANCE_MODE=false

