{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm exec turbo run build --filter=@cardmkt/web"
  },
  "deploy": {
    "startCommand": "pnpm --filter @cardmkt/web exec next start -p ${PORT:-3000}",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
